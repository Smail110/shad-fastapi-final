# REST Client requests for book marketplace
# Extension: humao.rest-client

@host = http://localhost:8000
@contentType = application/json

###
# 1. Регистрация продавца
POST {{host}}/api/v1/seller/ HTTP/1.1
Content-Type: {{contentType}}

{
  "first_name": "Ivan",
  "last_name": "Petrov",
  "e_mail": "ivan@example.com",
  "password": "123456"
}

###
# 2. Получить список всех продавцов
GET {{host}}/api/v1/seller/ HTTP/1.1

###
# 3. Получить JWT токен
# Скопируйте access_token из ответа
POST {{host}}/api/v1/token/ HTTP/1.1
Content-Type: {{contentType}}

{
  "e_mail": "ivan@example.com",
  "password": "123456"
}

###
# 4. Получить конкретного продавца по id
# Вставьте токен вместо YOUR_TOKEN
GET {{host}}/api/v1/seller/1 HTTP/1.1
Authorization: Bearer YOUR_TOKEN

###
# 5. Обновить продавца
PUT {{host}}/api/v1/seller/1 HTTP/1.1
Content-Type: {{contentType}}

{
  "first_name": "IvanUpdated",
  "last_name": "PetrovUpdated",
  "e_mail": "ivan_updated@example.com"
}

###
# 6. Создать книгу
# Вставьте токен вместо YOUR_TOKEN
POST {{host}}/api/v1/books/ HTTP/1.1
Content-Type: {{contentType}}
Authorization: Bearer YOUR_TOKEN

{
  "title": "Clean Architecture",
  "author": "Robert Martin",
  "count_pages": 300,
  "year": 2025,
  "seller_id": 1
}

###
# 7. Получить список всех книг
GET {{host}}/api/v1/books/ HTTP/1.1

###
# 8. Получить одну книгу по id
GET {{host}}/api/v1/books/1 HTTP/1.1

###
# 9. Полностью обновить книгу
# Вставьте токен вместо YOUR_TOKEN
PUT {{host}}/api/v1/books/1 HTTP/1.1
Content-Type: {{contentType}}
Authorization: Bearer YOUR_TOKEN

{
  "id": 1,
  "title": "Clean Code",
  "author": "Robert Martin",
  "year": 2025,
  "pages": 310,
  "seller_id": 1
}

###
# 10. Частично обновить книгу
PATCH {{host}}/api/v1/books/1 HTTP/1.1
Content-Type: {{contentType}}

{
  "title": "Refactored Book Title",
  "pages": 320
}

###
# 11. Удалить книгу
DELETE {{host}}/api/v1/books/1 HTTP/1.1

###
# 12. Удалить продавца
# Вместе с продавцом должны удалиться и его книги
DELETE {{host}}/api/v1/seller/1 HTTP/1.1

###
# 13. Проверка: получить несуществующую книгу после удаления
GET {{host}}/api/v1/books/1 HTTP/1.1

###
# 14. Проверка: получить токен с неверным паролем
POST {{host}}/api/v1/token/ HTTP/1.1
Content-Type: {{contentType}}

{
  "e_mail": "ivan@example.com",
  "password": "wrong_password"
}

###
# 15. Проверка: создать книгу без токена
POST {{host}}/api/v1/books/ HTTP/1.1
Content-Type: {{contentType}}

{
  "title": "Unauthorized Book",
  "author": "Unknown",
  "count_pages": 100,
  "year": 2025,
  "seller_id": 1
}

###
# 16. Проверка: получить продавца без токена
GET {{host}}/api/v1/seller/1 HTTP/1.1